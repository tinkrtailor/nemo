# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Rust
target/
**/*.rs.bk

# Node (opencode deps)
node_modules/

# Tool session data
.gstack/

# Claude local settings (contains permission grants, not shared)
.claude/settings.local.json

# Secrets — NEVER commit resolved env files
.env
.env.*
*.pem
*.key

# 1Password reference files are safe to commit (contain only op:// URIs)
!.env.1password
!terraform/.env.1password

# Terraform
terraform/.terraform/
terraform/**/.terraform/
terraform/*.tfstate*
terraform/**/*.tfstate*
terraform/kubeconfig.yaml
terraform/*.tfvars
terraform/**/*.tfvars
terraform/modules/nautiloop/.state/
