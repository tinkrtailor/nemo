# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Rust
target/
**/*.rs.bk

# Node (opencode deps)
node_modules/

# Tool session data
.gstack/

# Internal agent review artifacts
.agent/

# Claude local settings and ephemeral state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Secrets — NEVER commit resolved env files
.env
.env.*
*.pem
*.key

# 1Password reference files are safe to commit (contain only op:// URIs)
!.env.1password
!terraform/.env.1password

# Terraform
terraform/.terraform/
terraform/**/.terraform/
terraform/*.tfstate*
terraform/**/*.tfstate*
terraform/kubeconfig.yaml
terraform/*.tfvars
terraform/**/*.tfvars
terraform/modules/nautiloop/.state/
