#!/usr/bin/env bash
# nautiloop-agent-entry: Agent entrypoint script for Nautiloop agent jobs.
# FR-4 through FR-13: Stage dispatch, environment setup, result output.
set -euo pipefail

# --- FR-30: Wait for sidecar readiness (Finding 10: integer arithmetic, no bc) ---
READY_FILE="/tmp/shared/ready"
TIMEOUT=30
ELAPSED=0

while [ ! -f "$READY_FILE" ]; do
    ELAPSED=$((ELAPSED + 1))
    if [ "$ELAPSED" -ge "$((TIMEOUT * 10))" ]; then
        echo "NAUTILOOP_ERROR: sidecar: readiness timeout after ${TIMEOUT}s" >&2
        exit 1
    fi
    sleep 0.1
done

# --- Validate required environment variables (Edge Case: Template variable not set) ---
required_vars="STAGE SPEC_PATH BRANCH SHA ROUND LOOP_ID"
missing=""
for var in $required_vars; do
    if [ -z "${!var:-}" ]; then
        missing="$missing $var"
    fi
done
if [ -n "$missing" ]; then
    echo "NAUTILOOP_ERROR: entrypoint: missing required environment variables:$missing" >&2
    exit 1
fi

# --- Check worktree mount (Edge Case: Worktree volume not mounted) ---
if [ ! -d "/work" ] || { [ ! -f "/work/.git" ] && [ ! -d "/work/.git" ]; }; then
    echo "NAUTILOOP_ERROR: entrypoint: worktree volume not found at /work" >&2
    exit 1
fi

# --- FR-4: Load prompt template ---
# FR-34: Repo-side overrides take precedence
STAGE_FILENAME=""
case "$STAGE" in
    implement) STAGE_FILENAME="implement.md" ;;
    revise)    STAGE_FILENAME="spec-revise.md" ;;
    review)    STAGE_FILENAME="review.md" ;;
    audit)     STAGE_FILENAME="spec-audit.md" ;;
    test)      ;; # No prompt template for test stage
    *)
        echo "NAUTILOOP_ERROR: entrypoint: unknown stage '$STAGE'" >&2
        exit 1
        ;;
esac

PROMPT_CONTENT=""
if [ -n "$STAGE_FILENAME" ]; then
    REPO_PROMPT="/work/.nautiloop/prompts/$STAGE_FILENAME"
    DEFAULT_PROMPT="/etc/nautiloop/prompts/$STAGE_FILENAME"

    if [ -f "$REPO_PROMPT" ]; then
        PROMPT_CONTENT=$(cat "$REPO_PROMPT")
    elif [ -f "$DEFAULT_PROMPT" ]; then
        PROMPT_CONTENT=$(cat "$DEFAULT_PROMPT")
    else
        echo "NAUTILOOP_ERROR: entrypoint: prompt template not found: $STAGE_FILENAME" >&2
        exit 1
    fi

    # FR-39: Variable injection
    SPEC_CONTENT=""
    if [ -f "/work/$SPEC_PATH" ]; then
        SPEC_CONTENT=$(cat "/work/$SPEC_PATH")
    fi

    FEEDBACK_CONTENT=""
    if [ -n "${FEEDBACK_PATH:-}" ] && [ -f "$FEEDBACK_PATH" ]; then
        FEEDBACK_CONTENT=$(cat "$FEEDBACK_PATH")
    fi

    DIFF_CONTENT=""
    if [ "$STAGE" = "review" ] || [ "$STAGE" = "audit" ]; then
        # Generate diff for review context using the resolved base branch
        BASE_REF="origin/${NAUTILOOP_BASE_BRANCH:-main}"
        DIFF_CONTENT=$(cd /work && git diff "${BASE_REF}...$SHA" 2>/dev/null || echo "")
    fi

    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{SPEC\}\}/$SPEC_CONTENT}"
    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{DIFF\}\}/$DIFF_CONTENT}"
    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{FEEDBACK\}\}/$FEEDBACK_CONTENT}"
    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{BRANCH\}\}/$BRANCH}"
    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{SHA\}\}/$SHA}"
    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{AFFECTED_SERVICES\}\}/${AFFECTED_SERVICES:-[]}}"

    # Write assembled prompt to a temp file for CLI tools
    PROMPT_FILE="/tmp/nautiloop-prompt-$$"
    echo "$PROMPT_CONTENT" > "$PROMPT_FILE"
fi

# --- Sidecar connection check helper ---
check_sidecar() {
    if ! curl -sf http://localhost:9092/ >/dev/null 2>&1; then
        echo "NAUTILOOP_ERROR: sidecar: connection refused on proxy port 9092" >&2
        # FR-22: Exit code 111 for sidecar connection failure
        exit 111
    fi
}

# --- Helper: run CLI as child process, extract result, emit NAUTILOOP_RESULT: ---
# Finding 1: exec replaces the process, preventing NAUTILOOP_RESULT emission.
# Instead, run as child, capture output, extract final assistant payload.
#
# Optional env var STDIN_FILE: if set, redirect that file as the CLI's stdin.
# Used by review/audit (opencode v1.3+ removed --prompt-file; the prompt has
# to be piped in to avoid argv length limits on large specs/diffs).
run_and_emit_result() {
    local stage_name="$1"
    shift
    local cli_stdout="/tmp/cli-stdout-$$"
    local cli_stderr="/tmp/cli-stderr-$$"
    local exit_code=0

    # Run CLI, capturing stdout and stderr separately
    set +e
    if [ -n "${STDIN_FILE:-}" ]; then
        "$@" < "$STDIN_FILE" > "$cli_stdout" 2>"$cli_stderr"
    else
        "$@" > "$cli_stdout" 2>"$cli_stderr"
    fi
    exit_code=$?
    set -e

    if [ "$exit_code" -ne 0 ]; then
        local stderr_tail
        stderr_tail=$(tail -c 5000 "$cli_stderr" 2>/dev/null || echo "")
        # Build a failure result envelope.
        # `-c` is critical: the loop engine's `extract_nautiloop_result` in
        # control-plane/src/loop_engine/driver.rs scans pod log LINES for the
        # `NAUTILOOP_RESULT:` prefix and parses what comes after as JSON. If
        # the JSON is pretty-printed (default), only the first line matches
        # the prefix and that line is just `NAUTILOOP_RESULT:{` which fails
        # to parse, so the loop engine gets None and the verdict is lost.
        local result
        result=$(jq -nc \
            --arg stage "$stage_name" \
            --argjson exit_code "$exit_code" \
            --arg stderr "$stderr_tail" \
            '{stage: $stage, data: {exit_code: $exit_code, error: $stderr}}')
        echo "$result" > /output/result.json
        echo "NAUTILOOP_RESULT:$result"
        exit "$exit_code"
    fi

    # Build the result envelope WITHOUT passing the stage output through argv.
    # opencode's streaming JSON output can easily hit 15-30 KB (and claude's
    # stream-json even more), which pushed `jq -n --arg data "$result_data"`
    # past the kernel ARG_MAX and made the exec fail with:
    #
    #   /usr/local/bin/nautiloop-agent-entry: line 159: /usr/bin/jq:
    #   Argument list too long
    #
    # Both jq calls then failed, $result ended up empty, and the echo below
    # produced no NAUTILOOP_RESULT line for the loop-engine to ingest —
    # which the loop-engine logged as "No NAUTILOOP_RESULT line found in
    # pod logs" and retried until BackoffLimitExceeded.
    #
    # The fix is to feed the file to jq directly (--rawfile / --slurpfile /
    # stdin) so nothing large goes through argv at all.
    #
    # Dispatch rules:
    # - Claude stream-json (implement/revise): slurp the file, keep the
    #   last `{"type":"assistant",...}` object, fall back to the raw text
    #   if the file doesn't parse as JSON.
    # - OpenCode (review/audit): wrap the raw file contents as a string in
    #   the `data` field. The verdict schema downstream will parse it as
    #   needed — this keeps parity with the old behavior for the
    #   happy path and just stops blowing up on size.
    # `-c` (compact) is critical here: the loop engine's
    # extract_nautiloop_result in control-plane/src/loop_engine/driver.rs
    # scans pod log LINES for the `NAUTILOOP_RESULT:` prefix and parses
    # what follows as JSON. Without -c, jq pretty-prints the envelope
    # across multiple lines, only the first line gets the prefix, and that
    # line is just `NAUTILOOP_RESULT:{` which fails to parse, so the loop
    # engine logs "No NAUTILOOP_RESULT line found in pod logs" and retries.
    local result
    if [ "$stage_name" = "implement" ] || [ "$stage_name" = "revise" ]; then
        result=$(jq -nc \
            --arg stage "$stage_name" \
            --slurpfile events "$cli_stdout" \
            '{stage: $stage, data: ([$events[] | select(.type == "assistant")] | last // null)}' \
            2>/dev/null) || \
        result=$(jq -nc \
            --arg stage "$stage_name" \
            --rawfile data "$cli_stdout" \
            '{stage: $stage, data: $data}')
    else
        result=$(jq -nc \
            --arg stage "$stage_name" \
            --rawfile data "$cli_stdout" \
            '{stage: $stage, data: $data}')
    fi
    echo "$result" > /output/result.json
    echo "NAUTILOOP_RESULT:$result"
}

# --- FR-4: Stage dispatch ---
case "$STAGE" in
    implement|revise)
        # FR-5, FR-7: Claude Code for implement/revise
        # Use --prompt-file to avoid argv length limits on large specs/diffs
        CLAUDE_ARGS=(--prompt-file "$PROMPT_FILE" --output-format stream-json --dangerously-skip-permissions)
        if [ -n "${SESSION_ID:-}" ]; then
            CLAUDE_ARGS+=(--resume "$SESSION_ID")
        fi
        run_and_emit_result "$STAGE" claude "${CLAUDE_ARGS[@]}"
        ;;

    review|audit)
        # FR-6, FR-7: OpenCode for review/audit (read-only)
        export OPENCODE_PERMISSIONS='{"edit":"deny","bash":"deny","read":"allow"}'
        # opencode v1.3+ removed --prompt-file; the message is either a
        # positional arg or piped in via stdin. We pipe via stdin to avoid
        # argv length limits for large specs/diffs — same reasoning the
        # original --prompt-file code had.
        OPENCODE_ARGS=(run --format json)
        if [ -n "${SESSION_ID:-}" ]; then
            OPENCODE_ARGS+=(-s "$SESSION_ID")
        fi
        STDIN_FILE="$PROMPT_FILE" run_and_emit_result "$STAGE" opencode "${OPENCODE_ARGS[@]}"
        ;;

    test)
        # FR-42a through FR-42d: Run test commands for affected services
        if [ -z "${AFFECTED_SERVICES:-}" ]; then
            echo "NAUTILOOP_ERROR: test: AFFECTED_SERVICES not set" >&2
            exit 1
        fi

        # FR-42b: Read test commands from nemo.toml
        TOML_FILE="/work/nemo.toml"
        if [ ! -f "$TOML_FILE" ]; then
            echo "NAUTILOOP_ERROR: test: nemo.toml not found at $TOML_FILE" >&2
            exit 1
        fi

        TOML_JSON=$(tomlq -r . "$TOML_FILE")
        RESULTS="[]"
        ALL_PASSED=true
        CI_STATUS="passed"

        # Iterate over affected services
        for svc in $(echo "$AFFECTED_SERVICES" | jq -r '.[]'); do
            cmd=$(echo "$TOML_JSON" | jq -r ".services[\"$svc\"].test // empty")
            if [ -z "$cmd" ]; then
                # Service not found in config - unknown status
                RESULTS=$(echo "$RESULTS" | jq --arg name "$svc" --arg cmd "unknown" \
                    '. + [{"name": $name, "test_command": $cmd, "exit_code": -1, "stdout": "", "stderr": "service not found in nemo.toml"}]')
                CI_STATUS="unknown"
                ALL_PASSED=false
                continue
            fi

            # FR-42c: Run test, capture stdout and stderr separately (Finding 11)
            STDOUT_FILE="/tmp/test-stdout-$$-$svc"
            STDERR_FILE="/tmp/test-stderr-$$-$svc"
            set +e
            (cd /work && eval "$cmd") > "$STDOUT_FILE" 2>"$STDERR_FILE"
            TEST_EXIT=$?
            set -e

            STDOUT_PART=$(head -c 10000 "$STDOUT_FILE" 2>/dev/null || echo "")
            STDERR_PART=$(head -c 5000 "$STDERR_FILE" 2>/dev/null || echo "")

            RESULTS=$(echo "$RESULTS" | jq \
                --arg name "$svc" \
                --arg cmd "$cmd" \
                --argjson exit "$TEST_EXIT" \
                --arg stdout "$STDOUT_PART" \
                --arg stderr "$STDERR_PART" \
                '. + [{"name": $name, "test_command": $cmd, "exit_code": $exit, "stdout": $stdout, "stderr": $stderr}]')

            if [ "$TEST_EXIT" -ne 0 ]; then
                ALL_PASSED=false
                # Distinguish infra failures from test failures.
                # Exit codes 124 (timeout), 126 (not executable), 127 (not found),
                # and >= 128 (killed by signal) indicate infra issues.
                if [ "$TEST_EXIT" -eq 124 ] || [ "$TEST_EXIT" -ge 126 ]; then
                    CI_STATUS="unknown"
                elif [ "$CI_STATUS" = "passed" ]; then
                    CI_STATUS="failed"
                fi
            fi
        done

        # FR-42d: Write structured result
        RESULT_DATA=$(jq -n \
            --argjson services "$RESULTS" \
            --argjson all_passed "$ALL_PASSED" \
            --arg ci_status "$CI_STATUS" \
            '{services: $services, all_passed: $all_passed, ci_status: $ci_status, token_usage: {input: 0, output: 0}}')

        RESULT_ENVELOPE=$(jq -n --arg stage "test" --argjson data "$RESULT_DATA" '{stage: $stage, data: $data}')

        # FR-13: Write to /output/result.json and stdout with prefix
        echo "$RESULT_ENVELOPE" > /output/result.json
        echo "NAUTILOOP_RESULT:$RESULT_ENVELOPE"
        exit 0
        ;;

    *)
        echo "NAUTILOOP_ERROR: entrypoint: unknown stage '$STAGE'" >&2
        exit 1
        ;;
esac
