#!/usr/bin/env bash
# nautiloop-agent-entry: Agent entrypoint script for Nautiloop agent jobs.
# FR-4 through FR-13: Stage dispatch, environment setup, result output.
set -euo pipefail

# --- FR-30: Wait for sidecar readiness (Finding 10: integer arithmetic, no bc) ---
READY_FILE="/tmp/shared/ready"
TIMEOUT=30
ELAPSED=0

while [ ! -f "$READY_FILE" ]; do
    ELAPSED=$((ELAPSED + 1))
    if [ "$ELAPSED" -ge "$((TIMEOUT * 10))" ]; then
        echo "NAUTILOOP_ERROR: sidecar: readiness timeout after ${TIMEOUT}s" >&2
        exit 1
    fi
    sleep 0.1
done

# --- Auth-degraded watchdog ---
#
# The sidecar's model proxy writes /tmp/shared/auth-degraded after N
# consecutive OAuth refresh failures (see sidecar/src/model_proxy.rs
# AUTH_DEGRADED_THRESHOLD). When that file appears we abort the
# stage with the "auth expired" exit code so the control plane maps
# the failure to AWAITING_REAUTH instead of burning the rest of the
# stage budget on opencode's exponential retry of 502s.
#
# Background-poll every 5s. On detection: emit a NAUTILOOP_RESULT
# error envelope so `nemo logs` shows the cause, then SIGTERM the
# main entrypoint PID. tini (PID 1) propagates the signal to the
# whole pod and the K8s Job picks up exit 42 → AuthExpired.
AUTH_DEGRADED_FLAG="/tmp/shared/auth-degraded"
MAIN_PID=$$
(
    while true; do
        if [ -f "$AUTH_DEGRADED_FLAG" ]; then
            reason=$(cat "$AUTH_DEGRADED_FLAG" 2>/dev/null || echo "unknown")
            echo "NAUTILOOP_ERROR: sidecar reported auth-degraded; aborting stage" >&2
            # Best-effort jq — if absent we still emit a parseable line.
            if command -v jq >/dev/null 2>&1; then
                jq -nc \
                    --arg stage "${STAGE:-unknown}" \
                    --arg reason "$reason" \
                    '{stage: $stage, data: {exit_code: 42, error: ("Auth expired: " + $reason)}}' \
                    | sed 's/^/NAUTILOOP_RESULT:/'
            else
                printf 'NAUTILOOP_RESULT:{"stage":"%s","data":{"exit_code":42,"error":"Auth expired"}}\n' \
                    "${STAGE:-unknown}"
            fi
            # Signal the entrypoint. set -e on the main script will
            # propagate; we don't use kill -KILL so cleanup traps
            # (if any) get a chance to run.
            kill -TERM "$MAIN_PID" 2>/dev/null || true
            sleep 5
            kill -KILL "$MAIN_PID" 2>/dev/null || true
            exit 42
        fi
        sleep 5
    done
) &
AUTH_WATCHDOG_PID=$!
trap 'kill "$AUTH_WATCHDOG_PID" 2>/dev/null || true' EXIT
# Map SIGTERM (from the watchdog above) to the agent-expired exit code
# so the K8s Job carries the right signal up to the control plane.
trap 'exit 42' TERM

# --- Validate required environment variables (Edge Case: Template variable not set) ---
required_vars="STAGE SPEC_PATH BRANCH SHA ROUND LOOP_ID"
missing=""
for var in $required_vars; do
    if [ -z "${!var:-}" ]; then
        missing="$missing $var"
    fi
done
if [ -n "$missing" ]; then
    echo "NAUTILOOP_ERROR: entrypoint: missing required environment variables:$missing" >&2
    exit 1
fi

# --- Check worktree mount (Edge Case: Worktree volume not mounted) ---
if [ ! -d "/work" ] || { [ ! -f "/work/.git" ] && [ ! -d "/work/.git" ]; }; then
    echo "NAUTILOOP_ERROR: entrypoint: worktree volume not found at /work" >&2
    exit 1
fi

# --- FR-4: Load prompt template ---
# FR-34: Repo-side overrides take precedence
STAGE_FILENAME=""
case "$STAGE" in
    implement) STAGE_FILENAME="implement.md" ;;
    revise)    STAGE_FILENAME="spec-revise.md" ;;
    review)    STAGE_FILENAME="review.md" ;;
    audit)     STAGE_FILENAME="spec-audit.md" ;;
    test)      ;; # No prompt template for test stage
    *)
        echo "NAUTILOOP_ERROR: entrypoint: unknown stage '$STAGE'" >&2
        exit 1
        ;;
esac

PROMPT_CONTENT=""
if [ -n "$STAGE_FILENAME" ]; then
    REPO_PROMPT="/work/.nautiloop/prompts/$STAGE_FILENAME"
    DEFAULT_PROMPT="/etc/nautiloop/prompts/$STAGE_FILENAME"

    if [ -f "$REPO_PROMPT" ]; then
        PROMPT_CONTENT=$(cat "$REPO_PROMPT")
    elif [ -f "$DEFAULT_PROMPT" ]; then
        PROMPT_CONTENT=$(cat "$DEFAULT_PROMPT")
    else
        echo "NAUTILOOP_ERROR: entrypoint: prompt template not found: $STAGE_FILENAME" >&2
        exit 1
    fi

    # FR-39: Variable injection
    SPEC_CONTENT=""
    if [ -f "/work/$SPEC_PATH" ]; then
        SPEC_CONTENT=$(cat "/work/$SPEC_PATH")
    fi

    FEEDBACK_CONTENT=""
    if [ -n "${FEEDBACK_PATH:-}" ] && [ -f "$FEEDBACK_PATH" ]; then
        FEEDBACK_CONTENT=$(cat "$FEEDBACK_PATH")
    fi

    DIFF_CONTENT=""
    if [ "$STAGE" = "review" ] || [ "$STAGE" = "audit" ]; then
        # Generate diff for review context using the resolved base branch
        BASE_REF="origin/${NAUTILOOP_BASE_BRANCH:-main}"
        DIFF_CONTENT=$(cd /work && git diff "${BASE_REF}...$SHA" 2>/dev/null || echo "")
    fi

    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{SPEC\}\}/$SPEC_CONTENT}"
    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{DIFF\}\}/$DIFF_CONTENT}"
    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{FEEDBACK\}\}/$FEEDBACK_CONTENT}"
    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{BRANCH\}\}/$BRANCH}"
    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{SHA\}\}/$SHA}"
    PROMPT_CONTENT="${PROMPT_CONTENT//\{\{AFFECTED_SERVICES\}\}/${AFFECTED_SERVICES:-[]}}"

    # Write assembled prompt to a temp file for CLI tools
    PROMPT_FILE="/tmp/nautiloop-prompt-$$"
    echo "$PROMPT_CONTENT" > "$PROMPT_FILE"
fi

# --- Sidecar connection check helper ---
check_sidecar() {
    if ! curl -sf http://localhost:9092/ >/dev/null 2>&1; then
        echo "NAUTILOOP_ERROR: sidecar: connection refused on proxy port 9092" >&2
        # FR-22: Exit code 111 for sidecar connection failure
        exit 111
    fi
}

# --- Helper: run CLI as child process, extract result, emit NAUTILOOP_RESULT: ---
# Finding 1: exec replaces the process, preventing NAUTILOOP_RESULT emission.
# Instead, run as child, capture output, extract final assistant payload.
#
# Optional env var STDIN_FILE: if set, redirect that file as the CLI's stdin.
# Used by review/audit (opencode v1.3+ removed --prompt-file; the prompt has
# to be piped in to avoid argv length limits on large specs/diffs).
run_and_emit_result() {
    local stage_name="$1"
    shift
    local cli_cmd="$1"  # claude or opencode — used for extraction dispatch below
    local cli_stdout="/tmp/cli-stdout-$$"
    local cli_stderr="/tmp/cli-stderr-$$"
    local exit_code=0

    # Run CLI, capturing stdout and stderr separately
    set +e
    if [ -n "${STDIN_FILE:-}" ]; then
        "$@" < "$STDIN_FILE" > "$cli_stdout" 2>"$cli_stderr"
    else
        "$@" > "$cli_stdout" 2>"$cli_stderr"
    fi
    exit_code=$?
    set -e

    if [ "$exit_code" -ne 0 ]; then
        local stderr_tail stdout_tail
        stderr_tail=$(tail -c 5000 "$cli_stderr" 2>/dev/null || echo "")
        # Also capture the tail of stdout. Claude Code in --output-format
        # stream-json mode and opencode in --format json mode both write
        # structured diagnostics (including fatal errors like invalid model
        # names, auth failures, tool registration errors) to stdout rather
        # than stderr. Without this, every CLI regression where stdout
        # carries the real error and stderr is empty surfaces to the loop
        # engine as `{"error":""}` and the operator has to race-exec into
        # a pod that exits in <2 seconds to figure out what happened.
        # Specific example: claude v2.x `--model <unknown-alias>` exits 1
        # with the rejection message in a stream-json `{"type":"result",
        # "is_error":true,"result":"..."}` event on stdout, nothing on
        # stderr. With this change the message lands in the NAUTILOOP_RESULT
        # error envelope and `nemo logs <loop-id>` shows it directly.
        stdout_tail=$(tail -c 5000 "$cli_stdout" 2>/dev/null || echo "")
        # Build a failure result envelope.
        # `-c` is critical: the loop engine's `extract_nautiloop_result` in
        # control-plane/src/loop_engine/driver.rs scans pod log LINES for the
        # `NAUTILOOP_RESULT:` prefix and parses what comes after as JSON. If
        # the JSON is pretty-printed (default), only the first line matches
        # the prefix and that line is just `NAUTILOOP_RESULT:{` which fails
        # to parse, so the loop engine gets None and the verdict is lost.
        local result
        result=$(jq -nc \
            --arg stage "$stage_name" \
            --argjson exit_code "$exit_code" \
            --arg stderr "$stderr_tail" \
            --arg stdout "$stdout_tail" \
            '{stage: $stage, data: {exit_code: $exit_code, error: $stderr, stdout_tail: $stdout}}')
        echo "$result" > /output/result.json
        echo "NAUTILOOP_RESULT:$result"
        exit "$exit_code"
    fi

    # Build the result envelope WITHOUT passing the stage output through argv.
    # opencode's streaming JSON output can easily hit 15-30 KB (and claude's
    # stream-json even more), which pushed `jq -n --arg data "$result_data"`
    # past the kernel ARG_MAX and made the exec fail with:
    #
    #   /usr/local/bin/nautiloop-agent-entry: line 159: /usr/bin/jq:
    #   Argument list too long
    #
    # Both jq calls then failed, $result ended up empty, and the echo below
    # produced no NAUTILOOP_RESULT line for the loop-engine to ingest —
    # which the loop-engine logged as "No NAUTILOOP_RESULT line found in
    # pod logs" and retried until BackoffLimitExceeded.
    #
    # The fix is to feed the file to jq directly (--rawfile / --slurpfile /
    # stdin) so nothing large goes through argv at all.
    #
    # Dispatch rules:
    # - Claude stream-json (implement/revise): slurp the file, keep the
    #   last `{"type":"assistant",...}` object, fall back to the raw text
    #   if the file doesn't parse as JSON.
    # - OpenCode (review/audit): extract the LLM's final text-event
    #   payload as the AuditVerdict / ReviewVerdict JSON, pull
    #   token_usage from the last step_finish event, and wrap in the
    #   ReviewResultData envelope the loop-engine's
    #   control-plane/src/loop_engine/driver.rs parses via
    #   serde_json::from_value::<ReviewResultData>(data). The audit and
    #   review prompts in .nautiloop/prompts/spec-audit.md and
    #   .nautiloop/prompts/review.md both instruct the model to:
    #
    #     "Output ONLY the verdict JSON object as your final message.
    #      No markdown wrapping, no commentary, no prefix."
    #
    #   so the last `{type: "text"}` event's `.part.text` is expected
    #   to already be valid JSON matching AuditVerdict / ReviewVerdict
    #   ({clean, confidence, issues, summary, token_usage}). We parse
    #   it with `fromjson` and nest it under `verdict`. If that fails,
    #   fall back to the --rawfile wrap so the loop-engine at least
    #   sees *something* instead of hanging on a missing envelope —
    #   though it will still flag the verdict as malformed and retry.
    #
    # `-c` (compact) is critical here: the loop engine's
    # extract_nautiloop_result in control-plane/src/loop_engine/driver.rs
    # scans pod log LINES for the `NAUTILOOP_RESULT:` prefix and parses
    # what follows as JSON. Without -c, jq pretty-prints the envelope
    # across multiple lines, only the first line gets the prefix, and that
    # line is just `NAUTILOOP_RESULT:{` which fails to parse, so the loop
    # engine logs "No NAUTILOOP_RESULT line found in pod logs" and retries.
    local result
    if [ "$stage_name" = "implement" ] || [ "$stage_name" = "revise" ]; then
        # Claude stream-json: keep the last assistant event object as data.
        result=$(jq -nc \
            --arg stage "$stage_name" \
            --slurpfile events "$cli_stdout" \
            '{stage: $stage, data: ([$events[] | select(.type == "assistant")] | last // null)}' \
            2>/dev/null) || \
        result=$(jq -nc \
            --arg stage "$stage_name" \
            --rawfile data "$cli_stdout" \
            '{stage: $stage, data: $data}')
    elif [ "$cli_cmd" = "claude" ]; then
        # Claude stream-json for review/audit with a claude-* model.
        #
        # Claude Code emits the model's final text response in the
        # `result` event's `result` field (type=="result", subtype=="success"),
        # not as a separate assistant text-content block. The prompt instructs
        # the model to output only the verdict JSON, but in practice Claude
        # often adds a preamble sentence and wraps the JSON in a markdown
        # code fence (```json ... ```) even when told not to.
        #
        # Extraction strategy: find the first `{` and last `}` in the
        # result string — this reliably isolates the JSON object regardless
        # of surrounding text or fence wrapping.
        result=$(jq -nc \
            --arg stage "$stage_name" \
            --argjson exit_code "$exit_code" \
            --slurpfile events "$cli_stdout" \
            '
              def extract_json_from_result:
                # The result field may contain preamble text + the JSON in a
                # ```json...``` fence, or just the raw JSON object. Use split
                # on the fence markers (not character-position arithmetic,
                # which has jq-version-specific bugs with unicode strings).
                if contains("```json\n") then
                    split("```json\n")[1] |
                    if contains("\n```") then split("\n```")[0] else . end
                elif (contains("```\n") and contains("\n```")) then
                    split("```\n")[1] | split("\n```")[0]
                else
                    ltrimstr("\n") | ltrimstr(" ")
                end |
                ltrimstr("\n") | rtrimstr("\n") |
                fromjson;

              ($events
                | map(select(.type == "result" and .subtype == "success"))
                | last
                | .result
                | extract_json_from_result
              ) as $verdict
              |
              ($events
                | map(select(.type == "result" and .subtype == "success"))
                | last
                | .usage // {}
              ) as $usage
              |
              ($events
                | map(select(.type == "result" and .subtype == "success"))
                | last
                | .session_id // ""
              ) as $session_id
              |
              {
                stage: $stage,
                data: {
                  verdict: $verdict,
                  token_usage: {
                    input:  ($usage.input_tokens  // 0),
                    output: ($usage.output_tokens // 0)
                  },
                  exit_code: $exit_code,
                  session_id: $session_id
                }
              }
            ' 2>/dev/null) || \
        result=$(jq -nc \
            --arg stage "$stage_name" \
            --rawfile data "$cli_stdout" \
            '{stage: $stage, data: $data}')
    else
        # OpenCode streaming JSON for review/audit with an OpenAI model.
        result=$(jq -nc \
            --arg stage "$stage_name" \
            --argjson exit_code "$exit_code" \
            --slurpfile events "$cli_stdout" \
            '
              ($events
                | map(select(.type == "text" and (.part.text // "") != ""))
                | last
                | .part.text
                | fromjson
              ) as $verdict
              |
              ($events
                | map(select(.type == "step_finish"))
                | last
                | .part.tokens // {}
              ) as $tokens
              |
              ($events
                | map(.sessionID // empty)
                | last // ""
              ) as $session_id
              |
              {
                stage: $stage,
                data: {
                  verdict: $verdict,
                  token_usage: {
                    input:  ($tokens.input  // 0),
                    output: ($tokens.output // 0)
                  },
                  exit_code: $exit_code,
                  session_id: $session_id
                }
              }
            ' 2>/dev/null) || \
        result=$(jq -nc \
            --arg stage "$stage_name" \
            --rawfile data "$cli_stdout" \
            '{stage: $stage, data: $data}')
    fi
    echo "$result" > /output/result.json
    echo "NAUTILOOP_RESULT:$result"
}

# --- Copy Claude credentials to writable ~/.claude/ ---
# Credentials are mounted read-only at /secrets/claude-creds/.credentials.json.
# Claude Code (v2.x+) needs to write session-env/ and other runtime directories
# under ~/.claude/, so we copy the credentials file into the writable home EmptyDir.
if [ -f "/secrets/claude-creds/.credentials.json" ]; then
    mkdir -p "${HOME}/.claude"
    cp /secrets/claude-creds/.credentials.json "${HOME}/.claude/.credentials.json"
fi

# --- FR-4: Stage dispatch ---
case "$STAGE" in
    implement|revise)
        # FR-5, FR-7: Claude Code for implement/revise.
        #
        # Claude Code v2.x removed `--prompt-file`; the CLI now takes the
        # prompt as either a positional argument or via stdin. We pipe
        # via stdin (same pattern as the opencode path for review/audit,
        # see #51) to avoid argv length limits on large specs/diffs —
        # which is the whole reason the original code used --prompt-file.
        # Symptom of the regression on a fresh v0.3.5 install:
        #
        #   NAUTILOOP_RESULT:{"stage":"revise","data":{
        #     "exit_code":1,
        #     "error":"error: unknown option '--prompt-file'"
        #   }}
        #
        # The stage exits 1, the K8s Job retries 2x in ~10 seconds each,
        # and the loop FAILs as BackoffLimitExceeded without ever running
        # any agent work. This blocked every implement/revise stage — so
        # after the audit path got unblocked (#84, #86), loops now reach
        # HARDENING -> dispatch_revise and then die here because the
        # revise stage can't start.
        #
        # `--print` is required for non-interactive mode in v2.x —
        # the CLI starts an interactive session by default. The docs
        # state that `--output-format`, `--input-format`, and
        # `--max-budget-usd` all only work with `--print`.
        #
        # `--verbose` is required by v2.x when combining `--print` with
        # `--output-format=stream-json`. Without it, claude exits 1 with:
        #
        #   Error: When using --print, --output-format=stream-json
        #          requires --verbose
        #
        # stream-json is the shape the downstream extractor expects
        # (see run_and_emit_result's `jq -s '[.[] | select(.type ==
        # "assistant")] | last'` filter), so we opt into --verbose
        # rather than fall back to `json`.
        CLAUDE_ARGS=(--print --output-format stream-json --verbose --dangerously-skip-permissions)
        if [ -n "${MODEL:-}" ]; then
            CLAUDE_ARGS+=(--model "$MODEL")
        fi
        # NOTE: We intentionally do NOT pass --resume here.
        # Claude Code sessions are stored in the container's emptyDir volume
        # (/home/agent/.claude) which is NOT persistent across pod boundaries.
        # Passing --resume <uuid> from a previous pod always fails with
        # "No conversation found with session ID: <uuid>" which causes the
        # K8s job to hit BackoffLimitExceeded. Each implement/revise pod
        # starts a fresh Claude session. Session persistence via PVC is a
        # future enhancement tracked separately.
        echo "[${STAGE}/r${ROUND}] Starting ${STAGE} (loop ${LOOP_ID}, branch ${BRANCH})"
        STDIN_FILE="$PROMPT_FILE" run_and_emit_result "$STAGE" claude "${CLAUDE_ARGS[@]}"
        ;;

    review|audit)
        # FR-6, FR-7: Cross-model review for review/audit (read-only).
        # Route to claude CLI for claude-* models, opencode for OpenAI models.
        REVIEW_MODEL="${MODEL:-gpt-4o-mini}"
        case "$REVIEW_MODEL" in
            claude-*)
                # Use Claude Code CLI for Claude models (same as implement/revise).
                CLAUDE_ARGS=(--print --output-format stream-json --verbose --dangerously-skip-permissions)
                CLAUDE_ARGS+=(--model "$REVIEW_MODEL")
                # No --resume: same reason as implement/revise — claude sessions
                # live in the pod's emptyDir and don't survive across pods.
                echo "[${STAGE}/r${ROUND}] Starting ${STAGE} with claude (loop ${LOOP_ID})"
                STDIN_FILE="$PROMPT_FILE" run_and_emit_result "$STAGE" claude "${CLAUDE_ARGS[@]}"
                ;;
            *)
                # Use OpenCode for OpenAI (and other) models.
                export OPENCODE_PERMISSIONS='{"edit":"deny","bash":"deny","read":"allow"}'
                export OPENCODE_DISABLE_AUTOUPDATE=1
                export OPENCODE_DISABLE_MODELS_FETCH=1

                # Pin the provider to `openai` so opencode routes through the sidecar
                # model proxy (OPENAI_BASE_URL=http://localhost:9090/openai) instead
                # of falling back to its built-in `opencode/*` models that go to the
                # opencode.ai hosted backend with unknown billing. See issue #62.
                case "$REVIEW_MODEL" in
                    */*) OPENCODE_MODEL="$REVIEW_MODEL" ;;
                    *) OPENCODE_MODEL="openai/$REVIEW_MODEL" ;;
                esac

                OPENCODE_ARGS=(run --format json -m "$OPENCODE_MODEL")
                # Only resume an opencode ses_ session, not a Claude UUID.
                if [ -n "${SESSION_ID:-}" ] && \
                   printf '%s' "$SESSION_ID" | grep -Eq '^ses_[a-zA-Z0-9]+$'; then
                    OPENCODE_ARGS+=(-s "$SESSION_ID")
                fi
                # Read prompt and truncate if extremely large to avoid ARG_MAX
                PROMPT_CONTENT=$(cat "$PROMPT_FILE")
                if [ "${#PROMPT_CONTENT}" -gt 100000 ]; then
                    PROMPT_CONTENT="${PROMPT_CONTENT:0:100000}

...[truncated: prompt exceeded 100KB limit]"
                fi
                run_and_emit_result "$STAGE" opencode "${OPENCODE_ARGS[@]}" "$PROMPT_CONTENT"
                ;;
        esac
        ;;

    test)
        # FR-42a through FR-42d: Run test commands for affected services
        if [ -z "${AFFECTED_SERVICES:-}" ]; then
            echo "NAUTILOOP_ERROR: test: AFFECTED_SERVICES not set" >&2
            exit 1
        fi

        # If no services to test (empty array), emit a passed result immediately.
        # This handles repos with no [services] configured in nemo.toml.
        if [ "$(echo "$AFFECTED_SERVICES" | jq 'length')" -eq 0 ]; then
            RESULT_ENVELOPE='{"stage":"test","data":{"services":[],"all_passed":true,"ci_status":"passed","token_usage":{"input":0,"output":0}}}'
            echo "$RESULT_ENVELOPE" > /output/result.json
            echo "NAUTILOOP_RESULT:$RESULT_ENVELOPE"
            exit 0
        fi

        # FR-42b: Read test commands from nemo.toml
        TOML_FILE="/work/nemo.toml"
        if [ ! -f "$TOML_FILE" ]; then
            echo "NAUTILOOP_ERROR: test: nemo.toml not found at $TOML_FILE" >&2
            exit 1
        fi

        TOML_JSON=$(tomlq -r . "$TOML_FILE")
        RESULTS="[]"
        ALL_PASSED=true
        CI_STATUS="passed"

        # Iterate over affected services
        for svc in $(echo "$AFFECTED_SERVICES" | jq -r '.[]'); do
            cmd=$(echo "$TOML_JSON" | jq -r ".services[\"$svc\"].test // empty")
            if [ -z "$cmd" ]; then
                # Service not found in config - unknown status
                RESULTS=$(echo "$RESULTS" | jq --arg name "$svc" --arg cmd "unknown" \
                    '. + [{"name": $name, "test_command": $cmd, "exit_code": -1, "stdout": "", "stderr": "service not found in nemo.toml"}]')
                CI_STATUS="unknown"
                ALL_PASSED=false
                continue
            fi

            # FR-42c: Run test, capture stdout and stderr separately (Finding 11)
            STDOUT_FILE="/tmp/test-stdout-$$-$svc"
            STDERR_FILE="/tmp/test-stderr-$$-$svc"
            set +e
            (cd /work && eval "$cmd") > "$STDOUT_FILE" 2>"$STDERR_FILE"
            TEST_EXIT=$?
            set -e

            STDOUT_PART=$(head -c 10000 "$STDOUT_FILE" 2>/dev/null || echo "")
            STDERR_PART=$(head -c 5000 "$STDERR_FILE" 2>/dev/null || echo "")

            RESULTS=$(echo "$RESULTS" | jq \
                --arg name "$svc" \
                --arg cmd "$cmd" \
                --argjson exit "$TEST_EXIT" \
                --arg stdout "$STDOUT_PART" \
                --arg stderr "$STDERR_PART" \
                '. + [{"name": $name, "test_command": $cmd, "exit_code": $exit, "stdout": $stdout, "stderr": $stderr}]')

            if [ "$TEST_EXIT" -ne 0 ]; then
                ALL_PASSED=false
                # Distinguish infra failures from test failures.
                # Exit codes 124 (timeout), 126 (not executable), 127 (not found),
                # and >= 128 (killed by signal) indicate infra issues.
                if [ "$TEST_EXIT" -eq 124 ] || [ "$TEST_EXIT" -ge 126 ]; then
                    CI_STATUS="unknown"
                elif [ "$CI_STATUS" = "passed" ]; then
                    CI_STATUS="failed"
                fi
            fi
        done

        # FR-42d: Write structured result
        RESULT_DATA=$(jq -n \
            --argjson services "$RESULTS" \
            --argjson all_passed "$ALL_PASSED" \
            --arg ci_status "$CI_STATUS" \
            '{services: $services, all_passed: $all_passed, ci_status: $ci_status, token_usage: {input: 0, output: 0}}')

        RESULT_ENVELOPE=$(jq -n --arg stage "test" --argjson data "$RESULT_DATA" '{stage: $stage, data: $data}')

        # FR-13: Write to /output/result.json and stdout with prefix
        echo "$RESULT_ENVELOPE" > /output/result.json
        echo "NAUTILOOP_RESULT:$RESULT_ENVELOPE"
        exit 0
        ;;

    *)
        echo "NAUTILOOP_ERROR: entrypoint: unknown stage '$STAGE'" >&2
        exit 1
        ;;
esac
